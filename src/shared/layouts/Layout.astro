---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "KASI - Kroma AI Systems Inc. Intelligent systems, resilient data pipelines, and high-precision software architecture in Vancouver, BC." 
} = Astro.props;

import { getLocaleFromUrl } from '../i18n/utils';

const baseDomain = 'https://kasi.systems';
const canonicalURL = new URL(Astro.url.pathname, baseDomain).href;
const lang = getLocaleFromUrl(Astro.url);

const cleanPath = Astro.url.pathname.replace(/^\/(es|zh|pa)(?=\/|$)/, '');
const urlEn = new URL(cleanPath, baseDomain).href;
const urlEs = new URL('/es' + (cleanPath === '/' ? '' : cleanPath), baseDomain).href;
const urlZh = new URL('/zh' + (cleanPath === '/' ? '' : cleanPath), baseDomain).href;
const urlPa = new URL('/pa' + (cleanPath === '/' ? '' : cleanPath), baseDomain).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={urlEn} />
    <link rel="alternate" hreflang="es" href={urlEs} />
    <link rel="alternate" hreflang="zh" href={urlZh} />
    <link rel="alternate" hreflang="pa" href={urlPa} />
    <link rel="alternate" hreflang="x-default" href={urlEn} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/assets/logos/kasi.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="/assets/logos/kasi.png" />

    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Inter:wght@300;400;500;600;700&display=swap" />

    <!-- Real-world analytics deferred to protect Lighthouse performance metrics -->
    <script is:inline>
      window.addEventListener('load', () => {
        // Google Analytics 4 (GA4)
        const ga = document.createElement('script');
        ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-BG4YVZ25T5';
        ga.async = true;
        document.head.appendChild(ga);

        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-BG4YVZ25T5', { 'anonymize_ip': true });

        // Vercel Analytics
        const va = document.createElement('script');
        va.src = '/_vercel/insights/script.js';
        va.defer = true;
        document.head.appendChild(va);

        // Microsoft Clarity Analytics
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window,document,"clarity","script","xfbxtacamq");

        // Global Event Delegation to automatically track button and link clicks
        document.addEventListener('click', (event) => {
          const target = (event.target as HTMLElement).closest('a, button');
          if (!target) return;

          const text = target.textContent ? target.textContent.trim() : '';
          const href = target.getAttribute('href') || '';
          const id = target.id || '';
          const classes = target.className || '';

          let category = 'button_click';
          if (target.tagName.toLowerCase() === 'a') {
            category = href.startsWith('http') && !href.includes(window.location.hostname)
              ? 'outbound_link_click'
              : 'internal_link_click';
          }

          if ((window as any).gtag) {
            (window as any).gtag('event', 'click_interaction', {
              'element_text': text || target.getAttribute('aria-label') || id || 'unlabeled',
              'element_type': target.tagName.toLowerCase(),
              'element_id': id,
              'element_class': classes,
              'destination_url': href,
              'event_category': category
            });
          }
        });
      });
    </script>

    <!-- JSON-LD Structured Data Schema for Search Engines -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Kroma AI Systems Inc. (KASI)",
        "image": "https://kasi.systems/assets/logos/kasi.png",
        "url": "https://kasi.systems",
        "telephone": "+16045550192",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Downtown Vancouver",
          "addressLocality": "Vancouver",
          "addressRegion": "BC",
          "postalCode": "V6B",
          "addressCountry": "CA"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 49.2827,
          "longitude": -123.1207
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday"
          ],
          "opens": "09:00",
          "closes": "18:00"
        },
        "sameAs": [
          "https://github.com/gabrielnino/KASI"
        ],
        "priceRange": "$$"
      }
    </script>

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
