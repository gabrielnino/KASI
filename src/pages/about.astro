---
import Layout from '../shared/layouts/Layout.astro';
import Navbar from '../shared/components/Navbar.astro';
import Footer from '../shared/components/Footer.astro';
---

<Layout 
  title="About KASI - Plumber Tech Partners" 
  description="Kroma AI Systems Inc. (KASI): Discover our mission to bring high-precision web redesign, AI virtual dispatch, and Voice CRM systems to plumbers."
>
  <Navbar />

  <main>
  <!-- Institutional Hero -->
  <section class="viewport-section about-hero">
    <div class="glow-blur glow-blue" style="top: 20%; left: -5%;"></div>
    <div class="container hero-container-compact">
      <span class="badge">About KASI</span>
      <h1>Technical pragmatism & structural <span class="text-gradient">integrity</span></h1>
      <p class="large">
        We were born in Vancouver, BC, under a simple premise: unnecessary complexity in software is the worst enemy of business profitability.
      </p>
    </div>
  </section>

  <!-- Narrative Section (6/6 Grid) -->
  <section class="viewport-section narrative-section">
    <div class="container grid-12 narrative-grid">
      <!-- Left: Corporate Vision (6 cols) -->
      <div class="narrative-left">
        <span class="badge">Our Mission</span>
        <h2>The vision of Kroma AI Systems Inc.</h2>
        <p>
          Plumbing contractors often suffer from outdated websites, missed customer calls, and manual paperwork that delays billing. At Kroma AI Systems Inc. (KASI), we build high-precision systems to automate your office operations.
        </p>
        <p>
          We do not believe in endless meetings or bloated budgets. We focus on modern web redesign, 24/7 AI virtual assistant receptionists, and voice CRM integrations to keep your vans booked and your hands free.
        </p>
      </div>

      <!-- Right: Narrative and Vancouver Matrix (6 cols) -->
      <div class="narrative-right">
        <div class="matrix-card">
          <span class="matrix-tag">Geographical & Cultural Context</span>
          <h3>The Vancouver Matrix</h3>
          <p>
            We operate from Vancouver, BC, helping local plumbing contractors scale their businesses. We understand the local trade environment, the urgency of emergency dispatching, and the need for hands-free systems for technicians on site.
          </p>
          <p>
            Our visual and strategic identity stems from this local and global duality, channeling a silent message of trust, solidity, and connectivity into every system we build.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Emblem Breakdown: Dual-Layer Identity -->
  <section class="viewport-section emblem-section">
    <div class="glow-blur glow-cyan" style="bottom: 10%; right: 10%;"></div>
    <div class="container">
      <div class="section-header">
        <span class="badge">Our Brand</span>
        <h2>Symbolic Fusion & Identity Philosophy</h2>
        <p>
          KASI is not just a brand; it is a manifesto of technical realism and cultural alignment.
        </p>
      </div>

      <div class="emblem-grid grid-12">
        <div class="emblem-card left-card">
          <span class="emblem-tag">Layer A: Semantic Irony</span>
          <h3>"KASI" as Practical Realism</h3>
          <p class="irony-desc">
            In Spanish, KASI sounds exactly like <em>"casi"</em> (almost). Instead of hiding this, we weaponized it as our greatest strength:
          </p>
          <div class="irony-box">
            <span class="quote">"We are not perfect, but we KASI always deliver."</span>
          </div>
          <p>
            It acknowledges that in real-world engineering, there are no magical, bulletproof systems; there are only senior teams capable of anticipating failures and programming systems that self-recover under any adversity.
          </p>
        </div>
      </div>
    </div>
  </section>



  <!-- Technical Timeline -->
  <section class="viewport-section timeline-section">
    <div class="container">
      <div class="section-header">
        <span class="badge">Evolution</span>
        <h2>Our Technical Trajectory</h2>
        <p>From local software engineering integrations to specialized automations for the trades.</p>
      </div>

      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-badge">2023</div>
          <div class="timeline-panel">
            <h4>Founding of Kroma AI Systems Inc.</h4>
            <p>Legal registration in British Columbia, Canada, providing custom high-precision software integrations.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-badge">2024</div>
          <div class="timeline-panel">
            <h4>Birth of Web Redesigns & Contractor SEO</h4>
            <p>Developing ultra-fast, local search-optimized contractor websites to maximize lead phone calls.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-badge">2025</div>
          <div class="timeline-panel">
            <h4>Launch of Voice CRM Dictation Pipelines</h4>
            <p>Deploying advanced Whispering speech pipelines to log job materials and client history hands-free on-site.</p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-badge">2026</div>
          <div class="timeline-panel">
            <h4>KASI Plumber Tech Suite Launch</h4>
            <p>Unifying Web Redesign, AI Dispatch Reception, and Voice CRM into a single resilient suite for plumbers across North America.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="viewport-section values-section">
    <div class="container">
      <div class="section-header">
        <span class="badge">Our Values</span>
        <h2>Rigid Engineering Pillars</h2>
        <p>Principles that define how we write code and how we engage with your business.</p>
      </div>

      <div class="values-grid grid-12">
        <div class="card value-card">
          <div class="val-num">I</div>
          <h3>Technical Precision</h3>
          <p>We write clean, typed, and well-documented systems specifically built for the trade operations.</p>
        </div>

        <div class="card value-card">
          <div class="val-num">II</div>
          <h3>Data Resiliency</h3>
          <p>No customer inquiry or booking is ever lost. We build robust databases with offline capabilities.</p>
        </div>

        <div class="card value-card">
          <div class="val-num">III</div>
          <h3>Clean Architecture</h3>
          <p>We decouple your CRM, calendars, and website from physical servers for high stability and security.</p>
        </div>

        <div class="card value-card">
          <div class="val-num">IV</div>
          <h3>Total Automation</h3>
          <p>We automate booking, calendar dispatch, and client logging, saving hours of manual administrative office work.</p>
        </div>
      </div>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .about-hero {
    text-align: center;
  }

  .hero-container-compact {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  /* Narrative Grid (6/6) */
  .narrative-grid {
    align-items: center;
    gap: 32px;
  }

  .narrative-left {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .narrative-right {
    grid-column: 7 / 13;
  }

  .matrix-card {
    background: linear-gradient(135deg, rgba(0, 157, 255, 0.08), rgba(0, 200, 255, 0.03));
    border: 1px solid rgba(0, 157, 255, 0.2);
    border-radius: 20px;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .matrix-tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-cyan-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Emblem Section */
  .emblem-section {
    background: rgba(2, 11, 24, 0.5);
  }

  .emblem-grid {
    gap: 32px;
  }

  .emblem-card {
    grid-column: 3 / 11;
    background: var(--grad-dark-card);
    border: 1px solid rgba(230, 231, 234, 0.1);
    border-radius: 20px;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (max-width: 1024px) {
    .emblem-card {
      grid-column: 2 / 12;
    }
  }

  .emblem-tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-electric-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .emblem-card h3 {
    font-size: 1.5rem;
  }

  .irony-desc {
    font-size: 0.95rem;
    color: var(--color-silver-dark);
  }

  .irony-box {
    background: rgba(255, 255, 255, 0.02);
    border-left: 4px solid var(--color-cyan-accent);
    padding: var(--space-3) var(--space-4);
    border-radius: 0 8px 8px 0;
  }

  .irony-box .quote {
    font-style: italic;
    font-weight: 600;
    color: var(--color-white);
  }

  .emblem-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .emblem-bullets li {
    font-family: var(--font-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    position: relative;
    padding-left: var(--space-4);
  }

  .emblem-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-electric-blue);
  }

  .brand-kits-images {
    margin-top: var(--space-4);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(230, 231, 234, 0.1);
  }

  .about-brand-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Timeline */
  .timeline {
    position: relative;
    max-width: 800px;
    margin-inline: auto;
    padding-block: var(--space-5);
  }

  /* Line running through center */
  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(230, 231, 234, 0.1);
    transform: translateX(-50%);
  }

  .timeline-item {
    display: flex;
    justify-content: flex-end;
    position: relative;
    margin-bottom: var(--space-6);
    width: 50%;
    padding-right: var(--space-6);
  }

  /* Every second item goes right */
  .timeline-item:nth-child(even) {
    align-self: flex-end;
    justify-content: flex-start;
    margin-left: 50%;
    padding-right: 0;
    padding-left: var(--space-6);
  }

  .timeline-badge {
    position: absolute;
    right: -25px;
    top: 15px;
    background: var(--color-primary-navy);
    border: 2px solid var(--color-electric-blue);
    color: var(--color-cyan-accent);
    font-size: 0.85rem;
    font-weight: 700;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .timeline-item:nth-child(even) .timeline-badge {
    left: -25px;
    right: auto;
  }

  .timeline-panel {
    background: var(--grad-dark-card);
    border: 1px solid rgba(230, 231, 234, 0.08);
    border-radius: 16px;
    padding: var(--space-5);
    width: 100%;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  .timeline-panel h4 {
    margin-bottom: var(--space-2);
    font-size: 1.15rem;
  }

  .timeline-panel p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Values Section */
  .values-grid {
    gap: 24px;
  }

  .value-card {
    grid-column: span 3;
    padding: var(--space-6);
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: var(--space-3);
  }

  .val-num {
    font-size: 1.75rem;
    font-weight: 900;
    color: rgba(0, 157, 255, 0.3);
    font-family: var(--font-primary);
  }

  .value-card h3 {
    font-size: 1.25rem;
  }

  .value-card p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .narrative-left {
      grid-column: span 12;
      margin-bottom: var(--space-4);
    }

    .narrative-right {
      grid-column: span 12;
    }

    .emblem-card {
      grid-column: span 12;
    }

    .timeline::before {
      left: 20px;
    }

    .timeline-item {
      width: 100%;
      padding-left: var(--space-6) !important;
      padding-right: 0 !important;
      margin-left: 0 !important;
      justify-content: flex-start;
    }

    .timeline-badge {
      left: -5px !important;
      right: auto !important;
    }

    .value-card {
      grid-column: span 6;
    }
  }

  @media (max-width: 600px) {
    .value-card {
      grid-column: span 12;
      min-height: auto;
    }
  }
</style>
