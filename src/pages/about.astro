---
import Layout from '../shared/layouts/Layout.astro';
import Navbar from '../shared/components/Navbar.astro';
import Footer from '../shared/components/Footer.astro';
import { getLocaleFromUrl, useTranslations } from '../shared/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout 
  title="About KASI - Plumber Tech Partners" 
  description="Kroma AI Systems Inc. (KASI): Discover our mission to bring high-precision web redesign, AI virtual dispatch, and Voice CRM systems to plumbers."
>
  <Navbar />

  <main>
  <!-- Institutional Hero -->
  <section class="viewport-section about-hero">
    <div class="glow-blur glow-blue" style="top: 20%; left: -5%;"></div>
    <div class="container hero-container-compact">
      <span class="badge">{t('about.hero.badge')}</span>
      <h1>{t('about.hero.title')}<span class="text-gradient">{t('about.hero.titleGradient')}</span></h1>
      <p class="large">
        {t('about.hero.desc')}
      </p>
    </div>
  </section>

  <!-- Narrative Section (6/6 Grid) -->
  <section class="viewport-section narrative-section">
    <div class="container grid-12 narrative-grid">
      <!-- Left: Corporate Vision (6 cols) -->
      <div class="narrative-left">
        <span class="badge">{t('about.narrative.badge')}</span>
        <h2>{t('about.narrative.title')}</h2>
        <p>
          {t('about.narrative.para1')}
        </p>
        <p>
          {t('about.narrative.para2')}
        </p>
      </div>

      <!-- Right: Narrative and Vancouver Matrix (6 cols) -->
      <div class="narrative-right">
        <div class="matrix-card">
          <span class="matrix-tag">{t('about.vancouverMatrix.tag')}</span>
          <h3>{t('about.vancouverMatrix.title')}</h3>
          <p>
            {t('about.vancouverMatrix.para1')}
          </p>
          <p>
            {t('about.vancouverMatrix.para2')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Emblem Breakdown: Dual-Layer Identity -->
  <section class="viewport-section emblem-section">
    <div class="glow-blur glow-cyan" style="bottom: 10%; right: 10%;"></div>
    <div class="container">
      <div class="section-header">
        <span class="badge">{t('about.brand.badge')}</span>
        <h2>{t('about.brand.title')}</h2>
        <p>
          {t('about.brand.desc')}
        </p>
      </div>

      <div class="emblem-grid grid-12">
        <div class="emblem-card left-card">
          <span class="emblem-tag">{t('about.brand.layerA')}</span>
          <h3>{t('about.brand.layerATitle')}</h3>
          <p class="irony-desc">
            {t('about.brand.layerADesc')}
          </p>
          <div class="irony-box">
            <span class="quote">{t('about.brand.layerAQuote')}</span>
          </div>
          <p>
            {t('about.brand.layerAPara')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Timeline -->
  <section class="viewport-section timeline-section">
    <div class="container">
      <div class="section-header">
        <span class="badge">{t('about.timeline.badge')}</span>
        <h2>{t('about.timeline.title')}</h2>
        <p>{t('about.timeline.desc')}</p>
      </div>

      <div class="timeline">
        {t('about.timeline.events').map((evt: any) => (
          <div class="timeline-item">
            <div class="timeline-badge">{evt.year}</div>
            <div class="timeline-panel">
              <h3>{evt.title}</h3>
              <p>{evt.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="viewport-section values-section">
    <div class="container">
      <div class="section-header">
        <span class="badge">{t('about.values.badge')}</span>
        <h2>{t('about.values.title')}</h2>
        <p>{t('about.values.desc')}</p>
      </div>

      <div class="values-grid grid-12">
        {t('about.values.items').map((val: any) => (
          <div class="card value-card">
            <div class="val-num">{val.num}</div>
            <h3>{val.title}</h3>
            <p>{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .about-hero {
    text-align: center;
  }

  .hero-container-compact {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  /* Narrative Grid (6/6) */
  .narrative-grid {
    align-items: center;
    gap: 32px;
  }

  .narrative-left {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .narrative-right {
    grid-column: 7 / 13;
  }

  .matrix-card {
    background: linear-gradient(135deg, rgba(0, 157, 255, 0.08), rgba(0, 200, 255, 0.03));
    border: 1px solid rgba(0, 157, 255, 0.2);
    border-radius: 20px;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .matrix-tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-cyan-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Emblem Section */
  .emblem-section {
    background: rgba(2, 11, 24, 0.5);
  }

  .emblem-grid {
    gap: 32px;
  }

  .emblem-card {
    grid-column: 3 / 11;
    background: var(--grad-dark-card);
    border: 1px solid rgba(230, 231, 234, 0.1);
    border-radius: 20px;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  @media (max-width: 1024px) {
    .emblem-card {
      grid-column: 2 / 12;
    }
  }

  .emblem-tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: #C084FC;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .emblem-card h3 {
    font-size: 1.5rem;
  }

  .irony-desc {
    font-size: 0.95rem;
    color: var(--color-silver-dark);
  }

  .irony-box {
    background: rgba(255, 255, 255, 0.02);
    border-left: 4px solid var(--color-cyan-accent);
    padding: var(--space-3) var(--space-4);
    border-radius: 0 8px 8px 0;
  }

  .irony-box .quote {
    font-style: italic;
    font-weight: 600;
    color: var(--color-white);
  }

  .emblem-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .emblem-bullets li {
    font-family: var(--font-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    position: relative;
    padding-left: var(--space-4);
  }

  .emblem-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-electric-blue);
  }

  .brand-kits-images {
    margin-top: var(--space-4);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(230, 231, 234, 0.1);
  }

  .about-brand-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Timeline */
  .timeline {
    position: relative;
    max-width: 800px;
    margin-inline: auto;
    padding-block: var(--space-5);
  }

  /* Line running through center */
  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: rgba(230, 231, 234, 0.1);
    transform: translateX(-50%);
  }

  .timeline-item {
    display: flex;
    justify-content: flex-end;
    position: relative;
    margin-bottom: var(--space-6);
    width: 50%;
    padding-right: var(--space-6);
  }

  /* Every second item goes right */
  .timeline-item:nth-child(even) {
    align-self: flex-end;
    justify-content: flex-start;
    margin-left: 50%;
    padding-right: 0;
    padding-left: var(--space-6);
  }

  .timeline-badge {
    position: absolute;
    right: -25px;
    top: 15px;
    background: var(--color-primary-navy);
    border: 2px solid var(--color-electric-blue);
    color: var(--color-cyan-accent);
    font-size: 0.85rem;
    font-weight: 700;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .timeline-item:nth-child(even) .timeline-badge {
    left: -25px;
    right: auto;
  }

  .timeline-panel {
    background: var(--grad-dark-card);
    border: 1px solid rgba(230, 231, 234, 0.08);
    border-radius: 16px;
    padding: var(--space-5);
    width: 100%;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
  }

  .timeline-panel h4 {
    margin-bottom: var(--space-2);
    font-size: 1.15rem;
  }

  .timeline-panel p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Values Section */
  .values-grid {
    gap: 24px;
  }

  .value-card {
    grid-column: span 3;
    padding: var(--space-6);
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: var(--space-3);
  }

  .val-num {
    font-size: 1.75rem;
    font-weight: 900;
    color: rgba(0, 157, 255, 0.3);
    font-family: var(--font-primary);
  }

  .value-card h3 {
    font-size: 1.25rem;
  }

  .value-card p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .narrative-left {
      grid-column: span 12;
      margin-bottom: var(--space-4);
    }

    .narrative-right {
      grid-column: span 12;
    }

    .emblem-card {
      grid-column: span 12;
    }

    .timeline::before {
      left: 20px;
    }

    .timeline-item {
      width: 100%;
      padding-left: var(--space-6) !important;
      padding-right: 0 !important;
      margin-left: 0 !important;
      justify-content: flex-start;
    }

    .timeline-badge {
      left: -5px !important;
      right: auto !important;
    }

    .value-card {
      grid-column: span 6;
    }
  }

  @media (max-width: 600px) {
    .value-card {
      grid-column: span 12;
      min-height: auto;
    }
  }
</style>
