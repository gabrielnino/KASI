---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Ingeniería de Software de Alta Precisión" 
  description="KASI - Kroma AI Systems Inc. Sistemas inteligentes, pipelines de datos de alta resiliencia y arquitectura de software premium en Vancouver, BC. No somos perfectos, pero KASI siempre lo logramos."
>
  <Navbar />

  <!-- Hero Section -->
  <section class="hero-section">
    <div class="glow-blur glow-blue" style="top: 10%; left: -10%;"></div>
    <div class="glow-blur glow-cyan" style="bottom: 10%; right: -10%;"></div>
    
    <div class="container hero-container grid-12">
      <div class="hero-content">
        <span class="badge">Kroma AI Systems Inc.</span>
        <h1 class="hero-title">
          Sistemas Inteligentes & Pipelines <span class="text-gradient">Resilientes</span>
        </h1>
        <p class="large hero-subtitle">
          Construimos arquitecturas limpias y automatizaciones robustas que escalan tu negocio. Sin rodeos corporativos ni falsas promesas.
        </p>
        
        <!-- Semantic Ju-Jitsu Irony Alert -->
        <div class="irony-banner">
          <span class="irony-quote">"No somos perfectos, pero KASI siempre lo logramos."</span>
          <span class="irony-badge">Compromiso Real</span>
        </div>

        <div class="hero-actions">
          <a href="/contact" class="btn-primary">Construir Mi Sistema</a>
          <a href="/services" class="btn-secondary">Explorar Servicios</a>
        </div>
      </div>

      <div class="hero-visual">
        <div class="tech-cube-container">
          <div class="cube-mesh">
            <div class="cube-side front"></div>
            <div class="cube-side back"></div>
            <div class="cube-side left"></div>
            <div class="cube-side right"></div>
            <div class="cube-side top"></div>
            <div class="cube-side bottom"></div>
          </div>
          <!-- Neural nodes effect -->
          <div class="neural-core"></div>
          <div class="node node-1"></div>
          <div class="node node-2"></div>
          <div class="node node-3"></div>
          <div class="node node-4"></div>
          <div class="orbit-ring"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust & Metrics Strip -->
  <section class="metrics-section">
    <div class="container">
      <div class="metrics-grid">
        <div class="metric-item">
          <span class="metric-num">99.97%</span>
          <span class="metric-label">Uptime en Pipelines</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">3.5x</span>
          <span class="metric-label">Velocidad de Extracción</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">0%</span>
          <span class="metric-label">Pérdida de Datos</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">+$12M</span>
          <span class="metric-label">En Costos Optimizados</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Strip (4 Cards) -->
  <section class="services-strip">
    <div class="container">
      <div class="section-header">
        <span class="badge">Nuestras Capacidades</span>
        <h2>Ingeniería sin fricción para resolver problemas reales</h2>
        <p>Soluciones diseñadas por ingenieros senior para erradicar cuellos de botella operativos.</p>
      </div>

      <div class="services-grid grid-12">
        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
          </div>
          <div>
            <h3>Sistemas AI & Agentes</h3>
            <p>Modelos autónomos integrados en tus flujos para acelerar la toma de decisiones.</p>
          </div>
          <a href="/services#ai-solutions" class="card-link">Saber más →</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div>
            <h3>Pipelines de Datos</h3>
            <p>Extracción y procesamiento resiliente de gran escala con arquitecturas tolerantes a fallos.</p>
          </div>
          <a href="/services#automation" class="card-link">Saber más →</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div>
            <h3>Arquitectura Clean</h3>
            <p>Backend de alta estabilidad, desacoplado y listo para soportar flujos empresariales.</p>
          </div>
          <a href="/services#dev" class="card-link">Saber más →</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h3>Cloud & Resiliencia</h3>
            <p>Infraestructura escalable y blindada contra ataques, optimizando el consumo y costos.</p>
          </div>
          <a href="/services#cloud" class="card-link">Saber más →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Solutions -->
  <section class="solutions-featured">
    <div class="glow-blur glow-cyan" style="top: 30%; right: 10%;"></div>
    <div class="container">
      <div class="section-header">
        <span class="badge">Nuestros Logros</span>
        <h2>Sistemas implementados con éxito</h2>
        <p>Proyectos de ingeniería avanzada construidos para resolver desafíos complejos de integración y datos.</p>
      </div>

      <div class="solutions-grid">
        <div class="card solution-card">
          <div class="solution-header-info">
            <span class="solution-tag">Extracción de Datos</span>
            <h3>Pipeline Automatizado de Carga Logística</h3>
          </div>
          <p class="solution-desc">
            Extracción y normalización de información en tiempo real desde 40 terminales de carga en el puerto de Vancouver. Rediseñado con arquitectura limpia para resistir cambios de formato del 100% de las fuentes.
          </p>
          <div class="solution-stats">
            <div>
              <span class="stat-num">+350%</span>
              <span class="stat-lbl">Velocidad de proceso</span>
            </div>
            <div>
              <span class="stat-num">0.001%</span>
              <span class="stat-lbl">Tasa de error</span>
            </div>
          </div>
        </div>

        <div class="card solution-card">
          <div class="solution-header-info">
            <span class="solution-tag">Inteligencia Artificial</span>
            <h3>Motor de Clasificación de Documentos Aduaneros</h3>
          </div>
          <p class="solution-desc">
            Sistema de procesamiento y clasificación de manifiestos utilizando agentes de IA locales con seguridad militar, eliminando la filtración de información sensible a servidores de terceros.
          </p>
          <div class="solution-stats">
            <div>
              <span class="stat-num">98.4%</span>
              <span class="stat-lbl">Precisión de clasificación</span>
            </div>
            <div>
              <span class="stat-num">-80%</span>
              <span class="stat-lbl">Tiempo de auditoría</span>
            </div>
          </div>
        </div>

        <div class="card solution-card">
          <div class="solution-header-info">
            <span class="solution-tag">Infraestructura</span>
            <h3>Escalado Cloud Tolerante a Fallos</h3>
          </div>
          <p class="solution-desc">
            Migración e instrumentación de infraestructura legacy a contenedores serverless autorrecuperables. Monitoreo predictivo que detecta fallos de API externas antes de que afecten al cliente.
          </p>
          <div class="solution-stats">
            <div>
              <span class="stat-num">99.99%</span>
              <span class="stat-lbl">Disponibilidad real</span>
            </div>
            <div>
              <span class="stat-num">-42%</span>
              <span class="stat-lbl">Reducción de costos</span>
            </div>
          </div>
        </div>
      </div>

      <div class="solutions-action">
        <a href="/cases" class="btn-secondary">Ver Casos de Estudio Completos</a>
      </div>
    </div>
  </section>

  <!-- Process Section (4 steps) -->
  <section class="process-section">
    <div class="container">
      <div class="section-header">
        <span class="badge">El Flujo</span>
        <h2>¿Cómo eliminamos la fricción de tu proyecto?</h2>
        <p>Un camino transparente, centrado en código robusto y sin procesos burocráticos infinitos.</p>
      </div>

      <div class="process-steps">
        <div class="step-card">
          <div class="step-number">01</div>
          <div class="step-content">
            <h4>Análisis y Diagnóstico</h4>
            <p>Auditamos tu sistema actual o requerimientos técnicos sin venderte humo. Definimos qué es viable y qué no.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">02</div>
          <div class="step-content">
            <h4>Diseño de Arquitectura</h4>
            <p>Dibujamos el plano del sistema bajo principios de Clean Architecture. Acoplamiento mínimo, máxima estabilidad.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">03</div>
          <div class="step-content">
            <h4>Construcción Incremental</h4>
            <p>Despliegues continuos sobre entornos de staging para que valides el código y los flujos en tiempo real.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">04</div>
          <div class="step-content">
            <h4>Puesta en Producción y Blindaje</h4>
            <p>Migración optimizada, configuración de contingencias y monitoreo proactivo del sistema.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="final-cta">
    <div class="glow-blur glow-blue" style="bottom: -20%; left: 30%;"></div>
    <div class="container cta-container">
      <h2>¿Listo para construir sistemas de ingeniería real?</h2>
      <p class="large">
        Si buscas un equipo senior que asuma la responsabilidad total de tus sistemas de datos e integraciones de IA, hablemos hoy.
      </p>
      <div class="cta-buttons">
        <a href="/contact" class="btn-primary">Iniciar Proyecto de Consulta</a>
        <a href="/about" class="btn-secondary">Conocer Nuestro Lado Humano</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Hero Section styles */
  .hero-section {
    padding-top: calc(var(--space-12) + 40px);
    padding-bottom: var(--space-11);
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero-container {
    align-items: center;
  }

  .hero-content {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hero-title {
    font-size: clamp(2.8rem, 5vw, 4rem);
    line-height: 1.05;
    margin-top: var(--space-2);
  }

  .hero-subtitle {
    margin-bottom: var(--space-2);
  }

  .irony-banner {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed rgba(230, 231, 234, 0.15);
    border-radius: 12px;
    padding: var(--space-4) var(--space-5);
    position: relative;
    max-width: 500px;
    margin-bottom: var(--space-3);
  }

  .irony-quote {
    font-family: var(--font-primary);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-silver);
    font-weight: 600;
  }

  .irony-badge {
    position: absolute;
    top: -10px;
    right: 15px;
    background: var(--color-primary-blue);
    border: 1px solid var(--color-electric-blue);
    color: var(--color-cyan-accent);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
  }

  .hero-visual {
    grid-column: 7 / 13;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    height: 400px;
  }

  /* 3D Tech Cube CSS Animation */
  .tech-cube-container {
    width: 250px;
    height: 250px;
    perspective: 800px;
    position: relative;
  }

  .cube-mesh {
    width: 100%;
    height: 100%;
    position: absolute;
    transform-style: preserve-3d;
    animation: rotateCube 20s infinite linear;
  }

  .cube-side {
    position: absolute;
    width: 200px;
    height: 200px;
    top: 25px;
    left: 25px;
    background: rgba(10, 45, 86, 0.15);
    border: 2px solid rgba(0, 200, 255, 0.4);
    box-shadow: 0 0 15px rgba(0, 157, 255, 0.15);
    transition: all var(--transition-normal);
  }

  .cube-side::after {
    content: '';
    position: absolute;
    top: 10%;
    left: 10%;
    width: 80%;
    height: 80%;
    border: 1px solid rgba(0, 200, 255, 0.1);
    background: radial-gradient(circle, rgba(0,157,255,0.05) 0%, transparent 70%);
  }

  .front  { transform: translateZ(100px); }
  .back   { transform: rotateY(180deg) translateZ(100px); }
  .left   { transform: rotateY(-90deg) translateZ(100px); }
  .right  { transform: rotateY(90deg) translateZ(100px); }
  .top    { transform: rotateX(90deg) translateZ(100px); }
  .bottom { transform: rotateX(-90deg) translateZ(100px); }

  .neural-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 40px;
    height: 40px;
    background: var(--color-cyan-accent);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 35px var(--color-cyan-accent);
    animation: pulseCore 3s infinite ease-in-out;
  }

  /* Node orbits */
  .node {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-electric-blue);
    box-shadow: 0 0 10px var(--color-electric-blue);
  }

  .node-1 { top: 10%; left: 20%; animation: floatNode1 6s infinite ease-in-out; }
  .node-2 { bottom: 15%; right: 20%; animation: floatNode2 8s infinite ease-in-out; }
  .node-3 { top: 30%; right: 10%; animation: floatNode3 5s infinite ease-in-out; }
  .node-4 { bottom: 25%; left: 10%; animation: floatNode4 7s infinite ease-in-out; }

  .orbit-ring {
    position: absolute;
    top: 15px;
    left: 15px;
    width: 220px;
    height: 220px;
    border: 1px dashed rgba(230, 231, 234, 0.15);
    border-radius: 50%;
    transform: rotateX(75deg);
    animation: spinRing 25s infinite linear;
  }

  /* Metrics Section */
  .metrics-section {
    background: rgba(2, 11, 24, 0.6);
    border-block: 1px solid rgba(230, 231, 234, 0.05);
    padding-block: var(--space-6);
  }

  .metrics-grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-5);
  }

  .metric-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    min-width: 180px;
    text-align: center;
  }

  .metric-num {
    font-size: 3rem;
    font-weight: 800;
    font-family: var(--font-primary);
    color: var(--color-white);
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF, var(--color-cyan-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .metric-label {
    font-size: 0.85rem;
    color: var(--color-silver-dark);
    margin-top: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metric-divider {
    width: 1px;
    height: 50px;
    background-color: rgba(230, 231, 234, 0.1);
  }

  /* Section Header */
  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .section-header h2 {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
  }

  /* Services Strip Grid */
  .services-grid {
    gap: 24px;
  }

  .service-strip-card {
    grid-column: span 3;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    padding: var(--space-6);
    gap: var(--space-4);
  }

  .service-strip-card h3 {
    margin-bottom: var(--space-2);
    font-size: 1.25rem;
  }

  .service-strip-card p {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .card-icon-wrapper {
    background: rgba(0, 157, 255, 0.06);
    border: 1px solid rgba(0, 157, 255, 0.15);
    color: var(--color-electric-blue);
    border-radius: 12px;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-cyan-accent);
  }

  /* Solutions Featured */
  .solutions-featured {
    background: rgba(2, 11, 24, 0.3);
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: var(--space-7);
  }

  .solution-card {
    padding: var(--space-6) var(--space-6) var(--space-5);
    gap: var(--space-4);
  }

  .solution-tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-electric-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
    display: inline-block;
  }

  .solution-card h3 {
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .solution-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .solution-stats {
    display: flex;
    gap: var(--space-5);
    border-top: 1px solid rgba(230, 231, 234, 0.08);
    padding-top: var(--space-4);
  }

  .stat-num {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-white);
    font-family: var(--font-primary);
  }

  .stat-lbl {
    font-size: 0.75rem;
    color: var(--color-silver-dark);
    display: block;
    margin-top: 2px;
  }

  .solutions-action {
    text-align: center;
  }

  /* Process Section */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .step-card {
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(230, 231, 234, 0.06);
    border-radius: 16px;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: relative;
    overflow: hidden;
  }

  .step-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--color-electric-blue);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .step-card:hover::before {
    opacity: 1;
  }

  .step-number {
    font-size: 2.25rem;
    font-weight: 900;
    font-family: var(--font-primary);
    color: rgba(0, 200, 255, 0.35);
    line-height: 1;
  }

  .step-content h4 {
    margin-bottom: var(--space-2);
    font-size: 1.15rem;
  }

  .step-content p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    border-top: 1px solid rgba(230, 231, 234, 0.08);
    background: radial-gradient(circle at center, rgba(10, 45, 86, 0.2) 0%, transparent 70%);
  }

  .cta-container {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-container h2 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  /* Keyframe Animations */
  @keyframes rotateCube {
    0% { transform: rotateX(0deg) rotateY(0deg); }
    100% { transform: rotateX(360deg) rotateY(360deg); }
  }

  @keyframes pulseCore {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.8; }
    50% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; box-shadow: 0 0 45px var(--color-cyan-accent); }
  }

  @keyframes floatNode1 {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-15px) translateX(10px); }
  }

  @keyframes floatNode2 {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(12px) translateX(-15px); }
  }

  @keyframes floatNode3 {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-10px) translateX(-8px); }
  }

  @keyframes floatNode4 {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(8px) translateX(12px); }
  }

