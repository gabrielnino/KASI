---
import Layout from '../shared/layouts/Layout.astro';
import Navbar from '../shared/components/Navbar.astro';
import Footer from '../shared/components/Footer.astro';
import AICube from '../features/home/components/AICube.astro';
---

<Layout 
  title="Website Redesign, AI Assistant & Voice CRM for Plumbers" 
  description="KASI - Kroma AI Systems Inc. High-conversion web redesign, 24/7 AI virtual assistant scheduling, and hands-free voice CRM systems for professional plumbers. Make your phone ring and keep your hands free."
>
  <Navbar />

  <main>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="glow-blur glow-blue" style="top: 10%; left: -10%;"></div>
    <div class="glow-blur glow-cyan" style="bottom: 10%; right: -10%;"></div>
    
    <div class="container hero-container grid-12">
      <div class="hero-content">
        <span class="badge">Specialized Trade Systems</span>
        <h1 class="hero-title">
          Never Miss a Plumbing Call. <span class="text-gradient">Automatic</span> Bookings.
        </h1>
        <p class="large hero-subtitle">
          High-conversion website redesign, 24/7 AI virtual dispatchers, and hands-free Voice CRM systems. Designed specifically for professional plumbing contractors.
        </p>
        
        <!-- Semantic Ju-Jitsu Irony Alert -->
        <div class="irony-banner">
          <span class="irony-quote">"We are not perfect, but we KASI always deliver."</span>
          <span class="irony-badge">Plumbing Automation</span>
        </div>

        <div class="hero-actions">
          <a href="/contact" class="btn-primary">Request Free Consultation</a>
          <a href="/services" class="btn-secondary">Explore Services</a>
        </div>
      </div>

      <div class="hero-visual">
        <AICube />
      </div>
    </div>
  </section>

  <!-- Trust & Metrics Strip -->
  <section class="metrics-section">
    <div class="container">
      <div class="metrics-grid">
        <div class="metric-item">
          <span class="metric-num">98%</span>
          <span class="metric-label">Missed Calls Captured</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">+250%</span>
          <span class="metric-label">Local SEO traffic</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">45m</span>
          <span class="metric-label">Daily Admin Time Saved</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">18%+</span>
          <span class="metric-label">Web Conversion Rate</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Strip (4 Cards) -->
  <section class="services-strip">
    <div class="container">
      <div class="section-header">
        <span class="badge">Our Capabilities</span>
        <h2>Frictionless systems to scale your plumbing business</h2>
        <p>Solutions engineered to capture every lead, optimize search ranking, and eliminate paperwork.</p>
      </div>

      <div class="services-grid grid-12">
        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
          </div>
          <div>
            <h3>Website Redesign</h3>
            <p>Modern contractor sites optimized for local Google Search, fast mobile loading, and direct phone calls.</p>
          </div>
          <a href="/services#redesign" class="card-link">Learn more →</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div>
            <h3>AI Dispatch Assistant</h3>
            <p>24/7 AI agents responding to service texts and calls, booking appointments directly in your calendar.</p>
          </div>
          <a href="/services#assistant" class="card-link">Learn more →</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div>
            <h3>Voice CRM Systems</h3>
            <p>Hands-free admin. Dictate job notes, update customer files, and trigger invoices while on-site.</p>
          </div>
          <a href="/services#voice-crm" class="card-link">Learn more →</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h3>Calendar & Tool Sync</h3>
            <p>Direct integration with ServiceTitan, Housecall Pro, Google Calendar, and invoicing platforms.</p>
          </div>
          <a href="/services#integrations" class="card-link">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Solutions -->
  <section class="solutions-featured">
    <div class="glow-blur glow-cyan" style="top: 30%; right: 10%;"></div>
    <div class="container">
      <div class="section-header">
        <span class="badge">Our Achievements</span>
        <h2>Successfully Deployed Systems</h2>
        <p>Advanced engineering systems designed to drive real-world business results for plumbing contractors.</p>
      </div>

      <div class="solutions-grid">
        <div class="card solution-card">
          <div class="solution-header-info">
            <span class="solution-tag">Lead Generation</span>
            <h3>Vancouver Plumbing & Drain Co.</h3>
          </div>
          <p class="solution-desc">
            Deployed a complete website redesign and a custom SMS AI booking assistant to capture inbound local search leads. The system operates 24/7, booking jobs even when dispatchers are off.
          </p>
          <div class="solution-stats">
            <div>
              <span class="stat-num">+45%</span>
              <span class="stat-lbl">Booked service calls</span>
            </div>
            <div>
              <span class="stat-num">98.2%</span>
              <span class="stat-lbl">Response rate</span>
            </div>
          </div>
        </div>

        <div class="card solution-card">
          <div class="solution-header-info">
            <span class="solution-tag">Voice Operations</span>
            <h3>Fraser Valley Drain Technicians</h3>
          </div>
          <p class="solution-desc">
            Integrated a voice-to-text pipeline into the field team's CRM. Plumbers dictate job summaries and list materials used on-site, generating immediate billing sheets.
          </p>
          <div class="solution-stats">
            <div>
              <span class="stat-num">1.5 hrs</span>
              <span class="stat-lbl">Daily admin saved/tech</span>
            </div>
            <div>
              <span class="stat-num">-80%</span>
              <span class="stat-lbl">Billing delay</span>
            </div>
          </div>
        </div>

        <div class="card solution-card">
          <div class="solution-header-info">
            <span class="solution-tag">24/7 Dispatching</span>
            <h3>Apex Emergency Plumbing</h3>
          </div>
          <p class="solution-desc">
            Implemented a natural-language voice assistant that handles after-hours emergency calls, screens caller urgency, and schedules dispatch runs directly into the on-call plumber's calendar.
          </p>
          <div class="solution-stats">
            <div>
              <span class="stat-num">$18,000</span>
              <span class="stat-lbl">Revenue saved in Month 1</span>
            </div>
            <div>
              <span class="stat-num">99.9%</span>
              <span class="stat-lbl">Call answer rate</span>
            </div>
          </div>
        </div>
      </div>

      <div class="solutions-action">
        <a href="/cases" class="btn-secondary">View Full Case Studies</a>
      </div>
    </div>
  </section>

  <!-- Process Section (4 steps) -->
  <section class="process-section">
    <div class="container">
      <div class="section-header">
        <span class="badge">The Flow</span>
        <h2>How do we eliminate friction from your project?</h2>
        <p>A transparent path focused on robust code and zero endless bureaucratic processes.</p>
      </div>

      <div class="process-steps">
        <div class="step-card">
          <div class="step-number">01</div>
          <div class="step-content">
            <h4>System Audit</h4>
            <p>We review your current website, local SEO maps standing, and booking dispatch flow to find missed lead leak points.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">02</div>
          <div class="step-content">
            <h4>Redesign & AI Setup</h4>
            <p>We design a high-speed website and construct your custom AI receptionist to respond to texts and book calls instantly.</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">03</div>
          <div class="step-content">
            <h4>Voice CRM & App Sync</h4>
            <p>We integrate hands-free voice transcription with your existing service software (ServiceTitan, Google Calendar, etc.).</p>
          </div>
        </div>

        <div class="step-card">
          <div class="step-number">04</div>
          <div class="step-content">
            <h4>Local Launch & Scale</h4>
            <p>We go live, optimize local search tags to push you up on Google Maps, and ensure your vans stay fully booked.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="final-cta">
    <div class="glow-blur glow-blue" style="bottom: -20%; left: 30%;"></div>
    <div class="container cta-container">
      <h2>Ready to keep your plumbing vans fully booked?</h2>
      <p class="large">
        Get a modern high-conversion website, a 24/7 AI virtual scheduler, and a hands-free Voice CRM custom-built for your business.
      </p>
      <div class="cta-buttons">
        <a href="/contact" class="btn-primary">Request Free Consultation</a>
        <a href="/cases" class="btn-secondary">View Plumber Case Studies</a>
      </div>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero Section styles */
  .hero-section {
    padding-top: calc(var(--space-12) + 40px);
    padding-bottom: var(--space-11);
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero-container {
    align-items: center;
  }

  .hero-content {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hero-title {
    font-size: clamp(2.8rem, 5vw, 4rem);
    line-height: 1.05;
    margin-top: var(--space-2);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #E6E7EA;
    margin-bottom: var(--space-2);
    line-height: 1.6;
  }

  .irony-banner {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed rgba(230, 231, 234, 0.15);
    border-radius: 12px;
    padding: var(--space-4) var(--space-5);
    position: relative;
    max-width: 500px;
    margin-bottom: var(--space-3);
  }

  .irony-quote {
    font-family: var(--font-primary);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-silver);
    font-weight: 600;
  }

  .irony-badge {
    position: absolute;
    top: -10px;
    right: 15px;
    background: var(--color-primary-blue);
    border: 1px solid var(--color-electric-blue);
    color: var(--color-cyan-accent);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
  }

  .hero-visual {
    grid-column: 7 / 13;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    height: 400px;
    margin-top: -30px;
  }


  /* Metrics Section */
  .metrics-section {
    background: rgba(2, 11, 24, 0.6);
    border-block: 1px solid rgba(230, 231, 234, 0.05);
    padding-block: var(--space-6);
  }

  .metrics-grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-5);
  }

  .metric-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    min-width: 180px;
    text-align: center;
  }

  .metric-num {
    font-size: 3rem;
    font-weight: 800;
    font-family: var(--font-primary);
    color: var(--color-white);
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF, var(--color-cyan-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .metric-label {
    font-size: 0.85rem;
    color: var(--color-silver-dark);
    margin-top: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metric-divider {
    width: 1px;
    height: 50px;
    background-color: rgba(230, 231, 234, 0.1);
  }

  /* Section Header */
  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .section-header h2 {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
  }

  /* Services Strip Grid */
  .services-grid {
    gap: 24px;
  }

  .service-strip-card {
    grid-column: span 3;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    padding: var(--space-6);
    gap: var(--space-4);
  }

  .service-strip-card h3 {
    margin-bottom: var(--space-2);
    font-size: 1.25rem;
  }

  .service-strip-card p {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .card-icon-wrapper {
    background: rgba(0, 157, 255, 0.06);
    border: 1px solid rgba(0, 157, 255, 0.15);
    color: var(--color-electric-blue);
    border-radius: 12px;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-cyan-accent);
  }

  /* Solutions Featured */
  .solutions-featured {
    background: rgba(2, 11, 24, 0.3);
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: var(--space-7);
  }

  .solution-card {
    padding: var(--space-6) var(--space-6) var(--space-5);
    gap: var(--space-4);
  }

  .solution-tag {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-electric-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
    display: inline-block;
  }

  .solution-card h3 {
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .solution-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .solution-stats {
    display: flex;
    gap: var(--space-5);
    border-top: 1px solid rgba(230, 231, 234, 0.08);
    padding-top: var(--space-4);
  }

  .stat-num {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-white);
    font-family: var(--font-primary);
  }

  .stat-lbl {
    font-size: 0.75rem;
    color: var(--color-silver-dark);
    display: block;
    margin-top: 2px;
  }

  .solutions-action {
    text-align: center;
  }

  /* Process Section */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .step-card {
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(230, 231, 234, 0.06);
    border-radius: 16px;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: relative;
    overflow: hidden;
  }

  .step-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--color-electric-blue);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .step-card:hover::before {
    opacity: 1;
  }

  .step-number {
    font-size: 2.25rem;
    font-weight: 900;
    font-family: var(--font-primary);
    color: rgba(0, 200, 255, 0.35);
    line-height: 1;
  }

  .step-content h4 {
    margin-bottom: var(--space-2);
    font-size: 1.15rem;
  }

  .step-content p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    border-top: 1px solid rgba(230, 231, 234, 0.08);
    background: radial-gradient(circle at center, rgba(10, 45, 86, 0.2) 0%, transparent 70%);
  }

  .cta-container {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-container h2 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }


  /* Responsive styling */
  @media (max-width: 1024px) {
    .hero-content {
      grid-column: span 12;
      text-align: center;
      align-items: center;
      order: 1;
    }

    .hero-visual {
      grid-column: span 12;
      height: 320px;
      order: 2;
    }

    .irony-banner {
      align-items: center;
    }

    .services-grid .service-strip-card {
      grid-column: span 6;
    }

    .solutions-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .process-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: calc(var(--space-10) + 60px);
      padding-bottom: var(--space-8);
    }

    .hero-title {
      font-size: 2.2rem;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
      gap: var(--space-3);
    }

    .hero-actions .btn-primary, .hero-actions .btn-secondary {
      width: 100%;
    }

    .metrics-grid {
      flex-direction: column;
      gap: var(--space-4);
    }

    .metric-divider {
      display: none;
    }

    .services-grid .service-strip-card {
      grid-column: span 12;
    }

    .solutions-grid {
      grid-template-columns: 1fr;
    }

    .process-steps {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .cta-buttons .btn-primary, .cta-buttons .btn-secondary {
      width: 100%;
    }
  }
</style>
