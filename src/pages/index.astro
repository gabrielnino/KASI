---
import Layout from '../shared/layouts/Layout.astro';
import Navbar from '../shared/components/Navbar.astro';
import Footer from '../shared/components/Footer.astro';
import AICube from '../features/home/components/AICube.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../shared/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout 
  title="Plumbing Web Redesign & AI Dispatch in Vancouver | KASI" 
  description="High-conversion website redesign, 24/7 AI virtual dispatchers, and hands-free Voice CRM systems for professional plumbing contractors. Maximize your booking."
>
  <Navbar />

  <main>
  <!-- Hero Section -->
  <section class="viewport-section hero-section">
    <div class="glow-blur glow-blue" style="top: 10%; left: -10%;"></div>
    <div class="glow-blur glow-cyan" style="bottom: 10%; right: -10%;"></div>
    
    <div class="container hero-container grid-12">
      <div class="hero-content">
        <span class="badge">{t('home.badge')}</span>
        <h1 class="hero-title">
          {t('home.heroTitle')}<span class="text-gradient">{t('home.heroTitleGradient')}</span>{t('home.heroTitleEnd')}
        </h1>
        <p class="large hero-subtitle">
          {t('home.heroSubtitle')}
        </p>
        
        <!-- Semantic Ju-Jitsu Irony Alert -->
        <div class="irony-banner">
          <span class="irony-quote">"We are not perfect, but we KASI always deliver."</span>
          <span class="irony-badge">{t('home.ironyBadge')}</span>
        </div>

        <div class="hero-actions">
          <a href={getLocalizedPath('/contact', lang)} class="btn-primary">{t('home.ctaConsultation')}</a>
          <a href={getLocalizedPath('/services', lang)} class="btn-secondary">{t('home.ctaServices')}</a>
        </div>
      </div>

      <div class="hero-visual">
        <AICube />
      </div>
    </div>
  </section>

  <!-- Trust & Metrics Strip -->
  <section class="viewport-section metrics-section">
    <div class="container">
      <div class="metrics-grid">
        <div class="metric-item">
          <span class="metric-num">98%</span>
          <span class="metric-label">{t('home.metrics.captured')}</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">+250%</span>
          <span class="metric-label">{t('home.metrics.seo')}</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">45m</span>
          <span class="metric-label">{t('home.metrics.timeSaved')}</span>
        </div>
        <div class="metric-divider"></div>
        <div class="metric-item">
          <span class="metric-num">18%+</span>
          <span class="metric-label">{t('home.metrics.conversion')}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Strip (4 Cards) -->
  <section class="viewport-section services-strip">
    <div class="container">
      <div class="section-header">
        <span class="badge">{t('home.capabilities.badge')}</span>
        <h2>{t('home.capabilities.title')}</h2>
        <p>{t('home.capabilities.desc')}</p>
      </div>

      <div class="services-grid grid-12">
        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
          </div>
          <div>
            <h3>{t('home.capabilities.cards.redesign.title')}</h3>
            <p>{t('home.capabilities.cards.redesign.desc')}</p>
          </div>
          <a href={getLocalizedPath('/services#redesign', lang)} class="card-link">{t('home.capabilities.cards.redesign.link')}</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div>
            <h3>{t('home.capabilities.cards.assistant.title')}</h3>
            <p>{t('home.capabilities.cards.assistant.desc')}</p>
          </div>
          <a href={getLocalizedPath('/services#assistant', lang)} class="card-link">{t('home.capabilities.cards.assistant.link')}</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <div>
            <h3>{t('home.capabilities.cards.voiceCrm.title')}</h3>
            <p>{t('home.capabilities.cards.voiceCrm.desc')}</p>
          </div>
          <a href={getLocalizedPath('/services#voice-crm', lang)} class="card-link">{t('home.capabilities.cards.voiceCrm.link')}</a>
        </div>

        <div class="card service-strip-card">
          <div class="card-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="card-svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h3>{t('home.capabilities.cards.sync.title')}</h3>
            <p>{t('home.capabilities.cards.sync.desc')}</p>
          </div>
          <a href={getLocalizedPath('/services#integrations', lang)} class="card-link">{t('home.capabilities.cards.sync.link')}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Solutions -->
  <section class="viewport-section solutions-featured">
    <div class="glow-blur glow-cyan" style="top: 30%; right: 10%;"></div>
    <div class="container">
      <div class="section-header">
        <span class="badge">{t('home.achievements.badge')}</span>
        <h2>{t('home.achievements.title')}</h2>
        <p>{t('home.achievements.desc')}</p>
      </div>

      <div class="solutions-grid">
        {t('home.achievements.cards').map((card: any) => (
          <div class="card solution-card">
            <div class="solution-header-info">
              <span class="solution-tag">{card.tag}</span>
              <h3>{card.title}</h3>
            </div>
            <p class="solution-desc">
              {card.desc}
            </p>
            <div class="solution-stats">
              <div>
                <span class="stat-num">{card.stat1Num}</span>
                <span class="stat-lbl">{card.stat1Lbl}</span>
              </div>
              <div>
                <span class="stat-num">{card.stat2Num}</span>
                <span class="stat-lbl">{card.stat2Lbl}</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="solutions-action">
        <a href={getLocalizedPath('/cases', lang)} class="btn-secondary">{t('home.achievements.ctaCases')}</a>
      </div>
    </div>
  </section>

  <!-- Process Section (4 steps) -->
  <section class="viewport-section process-section">
    <div class="container">
      <div class="section-header">
        <span class="badge">{t('home.process.badge')}</span>
        <h2>{t('home.process.title')}</h2>
        <p>{t('home.process.desc')}</p>
      </div>

      <div class="process-steps">
        {t('home.process.steps').map((step: any) => (
          <div class="step-card">
            <div class="step-number">{step.num}</div>
            <div class="step-content">
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section class="viewport-section final-cta">
    <div class="glow-blur glow-blue" style="bottom: -20%; left: 30%;"></div>
    <div class="container cta-container">
      <h2>{t('home.finalCta.title')}</h2>
      <p class="large">
        {t('home.finalCta.desc')}
      </p>
      <div class="cta-buttons">
        <a href={getLocalizedPath('/contact', lang)} class="btn-primary">{t('home.finalCta.cta1')}</a>
        <a href={getLocalizedPath('/cases', lang)} class="btn-secondary">{t('home.finalCta.cta2')}</a>
      </div>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero Section styles */
  .hero-section {
    display: flex;
    align-items: center;
  }

  .hero-container {
    align-items: center;
  }

  .hero-content {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hero-title {
    font-size: clamp(2.8rem, 5vw, 4rem);
    line-height: 1.05;
    margin-top: var(--space-2);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #E6E7EA;
    margin-bottom: var(--space-2);
    line-height: 1.6;
  }

  .irony-banner {
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed rgba(230, 231, 234, 0.15);
    border-radius: 12px;
    padding: var(--space-4) var(--space-5);
    position: relative;
    max-width: 500px;
    margin-bottom: var(--space-3);
  }

  .irony-quote {
    font-family: var(--font-primary);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-silver);
    font-weight: 600;
  }

  .irony-badge {
    position: absolute;
    top: -10px;
    right: 15px;
    background: var(--color-primary-blue);
    border: 1px solid var(--color-electric-blue);
    color: var(--color-cyan-accent);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
  }

  .hero-visual {
    grid-column: 7 / 13;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    height: 500px;
    margin-top: -45px;
  }


  /* Metrics Section */
  .metrics-section {
    background: rgba(16, 8, 36, 0.6);
  }

  .metrics-grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-5);
  }

  .metric-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    min-width: 180px;
    text-align: center;
  }

  .metric-num {
    font-size: 3rem;
    font-weight: 800;
    font-family: var(--font-primary);
    color: var(--color-white);
    line-height: 1;
    background: linear-gradient(135deg, #FFFFFF, var(--color-cyan-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .metric-label {
    font-size: 0.85rem;
    color: var(--color-silver-dark);
    margin-top: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metric-divider {
    width: 1px;
    height: 50px;
    background-color: rgba(230, 231, 234, 0.1);
  }

  /* Section Header */
  .section-header {
    text-align: center;
    max-width: 700px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .section-header h2 {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
  }

  .solutions-featured {
    background: rgba(16, 8, 36, 0.2);
  }

  /* Services Strip Grid */
  .services-grid {
    gap: 24px;
  }

  .service-strip-card {
    grid-column: span 3;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    padding: var(--space-5);
    gap: var(--space-4);
  }

  .service-strip-card h3 {
    margin-bottom: var(--space-2);
    font-size: 1.25rem;
  }

  .service-strip-card p {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .card-icon-wrapper {
    background: rgba(111, 53, 252, 0.08);
    border: 1px solid rgba(111, 53, 252, 0.25);
    color: #C084FC;
    border-radius: 12px;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-link {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-cyan-accent);
  }



  .solutions-featured {
    padding-top: 70px;
    padding-bottom: 10px;
  }

  .solutions-featured .section-header {
    margin-bottom: var(--space-3);
  }

  .solutions-featured .section-header h2 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  .solutions-featured .section-header p {
    font-size: 0.95rem;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: var(--space-4);
  }

  .solution-card {
    padding: 18px var(--space-4);
    gap: 10px;
  }

  .solution-tag {
    font-size: 0.7rem;
    font-weight: 700;
    color: #C084FC;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2px;
    display: inline-block;
  }

  .solution-card h3 {
    font-size: 1.15rem;
    line-height: 1.25;
  }

  .solution-desc {
    font-size: 0.82rem;
    line-height: 1.5;
    margin-bottom: var(--space-1);
  }

  .solution-stats {
    display: flex;
    gap: var(--space-4);
    border-top: 1px solid rgba(230, 231, 234, 0.08);
    padding-top: var(--space-3);
  }

  .stat-num {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--color-white);
    font-family: var(--font-primary);
  }

  .stat-lbl {
    font-size: 0.7rem;
    color: var(--color-silver-dark);
    display: block;
    margin-top: 2px;
  }

  .solutions-action {
    text-align: center;
  }

  /* Process Section */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .step-card {
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(230, 231, 234, 0.06);
    border-radius: 16px;
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: relative;
    overflow: hidden;
  }

  .step-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--color-electric-blue);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .step-card:hover::before {
    opacity: 1;
  }

  .step-number {
    font-size: 2.25rem;
    font-weight: 900;
    font-family: var(--font-primary);
    color: rgba(0, 200, 255, 0.35);
    line-height: 1;
  }

  .step-content h4 {
    margin-bottom: var(--space-2);
    font-size: 1.15rem;
  }

  .step-content p {
    font-size: 0.85rem;
    line-height: 1.6;
  }

  /* Final CTA */
  .final-cta {
    text-align: center;
    background: radial-gradient(circle at center, rgba(111, 53, 252, 0.15) 0%, transparent 70%);
  }

  .cta-container {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .cta-container h2 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }


  /* Responsive styling */
  @media (max-width: 1024px) {
    .hero-content {
      grid-column: span 12;
      text-align: center;
      align-items: center;
      order: 1;
    }

    .hero-visual {
      grid-column: span 12;
      height: 320px;
      order: 2;
    }

    .irony-banner {
      align-items: center;
    }

    .services-grid .service-strip-card {
      grid-column: span 6;
    }

    .solutions-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .process-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: calc(var(--space-10) + 60px);
      padding-bottom: var(--space-8);
    }

    .hero-title {
      font-size: 2.2rem;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
      gap: var(--space-3);
    }

    .hero-actions .btn-primary, .hero-actions .btn-secondary {
      width: 100%;
    }

    .metrics-grid {
      flex-direction: column;
      gap: var(--space-4);
    }

    .metric-divider {
      display: none;
    }

    .services-grid .service-strip-card {
      grid-column: span 12;
    }

    .solutions-grid {
      grid-template-columns: 1fr;
    }

    .process-steps {
      grid-template-columns: 1fr;
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .cta-buttons .btn-primary, .cta-buttons .btn-secondary {
      width: 100%;
    }
  }

</style>
