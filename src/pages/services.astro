---
import Layout from '../shared/layouts/Layout.astro';
import Navbar from '../shared/components/Navbar.astro';
import Footer from '../shared/components/Footer.astro';
---

<Layout 
  title="Plumber SEO, AI Assistant & CRM | KASI" 
  description="High-conversion website redesign, local SEO, 24/7 AI virtual dispatch, and hands-free Voice CRM systems custom-built for plumbing contractors."
>
  <Navbar />

  <main>
  <!-- Mini Compact Hero -->
  <section class="viewport-section services-hero">
    <div class="glow-blur glow-blue" style="top: 20%; left: 10%;"></div>
    <div class="container hero-container-compact">
      <span class="badge">Our Specialty</span>
      <h1>High-Performance Systems for <span class="text-gradient">Plumbing</span> Businesses</h1>
      <p class="large">
        We build custom websites, AI virtual schedulers, and voice CRM integrations to keep your plumbing vans running and eliminate office admin.
      </p>
    </div>
  </section>

  <!-- Services Grid Section -->
  <section class="viewport-section services-grid-section">
    <div class="container">
      <div class="services-columns-grid">
        
        <!-- Service 1: Website Redesign -->
        <div class="card service-page-card" id="redesign">
          <div class="card-top">
            <div class="circular-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="svg-icon">
                <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                <path d="M12 6v12M6 12h12M7.5 7.5l9 9M7.5 16.5l9-9"/>
              </svg>
            </div>
            <h3>Website Redesign</h3>
            <p>
              Custom mobile-first websites engineered for speed and conversion. We integrate click-to-call buttons, trust badge displays, and interactive schedulers to convert local searchers into booked jobs.
            </p>
          </div>
          <div class="card-bottom">
            <ul class="bullet-tech">
              <li>Mobile-First Layouts</li>
              <li>Local SEO Optimization</li>
              <li>High Lead Conversion</li>
            </ul>
            <a href="/contact?service=redesign" class="btn-secondary compact-btn">Request Quote</a>
          </div>
        </div>

        <!-- Service 2: AI Dispatch Assistant -->
        <div class="card service-page-card" id="assistant">
          <div class="card-top">
            <div class="circular-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="svg-icon">
                <path d="M16 18l6-6-6-6M8 6l-6 6 6 6M12 4l-4 16"/>
              </svg>
            </div>
            <h3>AI Dispatch Assistant</h3>
            <p>
              A 24/7 natural-language virtual dispatcher responding to texts and calls. Qualifies service requests, handles emergency escalations, and books jobs directly in your dispatch board.
            </p>
          </div>
          <div class="card-bottom">
            <ul class="bullet-tech">
              <li>24/7 Lead Response</li>
              <li>Urgency Qualification</li>
              <li>Automated Scheduling</li>
            </ul>
            <a href="/contact?service=assistant" class="btn-secondary compact-btn">Request Quote</a>
          </div>
        </div>

        <!-- Service 3: Voice CRM Systems -->
        <div class="card service-page-card" id="voice-crm">
          <div class="card-top">
            <div class="circular-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="svg-icon">
                <path d="M17.5 19A5.5 5.5 0 0 0 18 8h-1.26a8 8 0 1 0-11.62 3.58"/>
                <path d="M12 12v9M9 18l3 3 3-3"/>
              </svg>
            </div>
            <h3>Voice CRM Systems</h3>
            <p>
              Dictate client notes, log materials used, update job status, and initiate invoicing directly on-site using only your voice. Eliminates manual typing on mobile screens while working.
            </p>
          </div>
          <div class="card-bottom">
            <ul class="bullet-tech">
              <li>Hands-free Dictation</li>
              <li>Acoustic Filtering</li>
              <li>Trade Term Recognition</li>
            </ul>
            <a href="/contact?service=voice-crm" class="btn-secondary compact-btn">Request Quote</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid Section 2 -->
  <section class="viewport-section services-grid-section">
    <div class="container">
      <div class="services-columns-grid">

        <!-- Service 4: Calendar & Tool Sync -->
        <div class="card service-page-card" id="integrations">
          <div class="card-top">
            <div class="circular-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="svg-icon">
                <path d="M2 17h20M2 12h20M2 7h20"/>
                <circle cx="5" cy="7" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="19" cy="17" r="1"/>
              </svg>
            </div>
            <h3>Calendar & Tool Sync</h3>
            <p>
              Automatic real-time synchronization between your website, AI assistant, and trade software. We connect directly to ServiceTitan, Housecall Pro, Google Calendar, and Quickbooks.
            </p>
          </div>
          <div class="card-bottom">
            <ul class="bullet-tech">
              <li>ServiceTitan Integration</li>
              <li>Housecall Pro API</li>
              <li>Quickbooks Invoicing</li>
            </ul>
            <a href="/contact?service=integrations" class="btn-secondary compact-btn">Request Quote</a>
          </div>
        </div>

        <!-- Service 5: Local SEO & Visibility -->
        <div class="card service-page-card" id="seo">
          <div class="card-top">
            <div class="circular-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="svg-icon">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <h3>Local SEO & Visibility</h3>
            <p>
              Optimization of local keyword targets and metadata to lift your plumbing business to the top of Google Maps and local search results, driving organic telephone calls.
            </p>
          </div>
          <div class="card-bottom">
            <ul class="bullet-tech">
              <li>Google Maps SEO</li>
              <li>Local Keyword Tuning</li>
              <li>Structured Schema Markup</li>
            </ul>
            <a href="/contact?service=seo" class="btn-secondary compact-btn">Request Quote</a>
          </div>
        </div>

        <!-- Service 6: Outage & Lead Resiliency -->
        <div class="card service-page-card" id="resiliency">
          <div class="card-top">
            <div class="circular-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="svg-icon">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
            </div>
            <h3>Outage & Lead Resiliency</h3>
            <p>
              Hardened hosting infrastructure with zero server downtime. Offline fallback systems capture and log customer booking inquiries even during network outages, ensuring zero lead loss.
            </p>
          </div>
          <div class="card-bottom">
            <ul class="bullet-tech">
              <li>99.99% Guaranteed Uptime</li>
              <li>Offline Intake Fallbacks</li>
              <li>Zero Lead Leakage</li>
            </ul>
            <a href="/contact?service=resiliency" class="btn-secondary compact-btn">Request Quote</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Focus Banner: Minimal Friction -->
  <section class="viewport-section friction-banner-section">
    <div class="container">
      <div class="friction-box">
        <div class="friction-content">
          <h3>Engineering Built for Trade Velocity</h3>
          <p>
            We eliminate low-value meetings and inflated tech budgets. We focus on clean systems that keep your plumbing vans booked, backed by documentation so any developer can maintain it.
          </p>
        </div>
        <div class="friction-action">
          <a href="/contact" class="btn-primary">Start Project Without Bureaucracy</a>
        </div>
      </div>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Compact Hero */
  .services-hero {
    text-align: center;
  }

  .hero-container-compact {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  /* Grid of services */
  .services-columns-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-page-card {
    min-height: 400px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-5);
  }

  .card-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .circular-icon {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(0, 157, 255, 0.05);
    border: 1px solid rgba(0, 157, 255, 0.2);
    color: var(--color-electric-blue);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-normal);
  }

  .service-page-card:hover .circular-icon {
    background: var(--color-electric-blue);
    color: var(--color-white);
    transform: scale(1.05);
    box-shadow: 0 0 20px rgba(0, 157, 255, 0.3);
  }

  .svg-icon {
    width: 24px;
    height: 24px;
  }

  .service-page-card h3 {
    font-size: 1.4rem;
  }

  .service-page-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-silver-dark);
  }

  .card-bottom {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bullet-tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .bullet-tech li {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-silver);
    padding: 4px 8px;
    border-radius: 4px;
    border: 1px solid rgba(230, 231, 234, 0.08);
  }

  .compact-btn {
    padding: 10px 16px;
    font-size: 0.85rem;
    width: 100%;
    text-align: center;
  }

  /* Friction Box */
  .friction-banner-section {
  }

  .friction-box {
    background: linear-gradient(135deg, rgba(10, 45, 86, 0.2) 0%, rgba(2, 11, 24, 0.8) 100%);
    border: 1px solid rgba(230, 231, 234, 0.08);
    border-radius: 24px;
    padding: var(--space-7) var(--space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .friction-content {
    flex: 1;
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .friction-content h3 {
    font-size: 1.75rem;
  }

  .friction-content p {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-silver);
  }

  .friction-action {
    flex-shrink: 0;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .services-columns-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .friction-box {
      flex-direction: column;
      text-align: center;
      padding: var(--space-6);
    }
  }

  @media (max-width: 768px) {
    .services-columns-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .service-page-card {
      min-height: 220px;
    }

    .friction-action {
      width: 100%;
    }

    .friction-action .btn-primary {
      width: 100%;
    }
  }
</style>
