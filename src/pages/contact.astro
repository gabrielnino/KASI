---
import Layout from '../shared/layouts/Layout.astro';
import Navbar from '../shared/components/Navbar.astro';
import Footer from '../shared/components/Footer.astro';
import ContactForm from '../features/contact/components/ContactForm.astro';
import { getLocaleFromUrl, useTranslations } from '../shared/i18n/utils';

const lang = getLocaleFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout 
  title="Contact KASI - Plumber Tech Setup" 
  description="Contact us today to design your plumbing website redesign, AI scheduler assistant, or voice CRM pipeline. Local support in Vancouver, BC."
>
  <Navbar />

  <main>
  <section class="contact-section">
    <div class="glow-blur glow-blue" style="top: 15%; left: 10%;"></div>
    <div class="glow-blur glow-cyan" style="bottom: 15%; right: 10%;"></div>
 
    <div class="container grid-12 contact-grid">
      <!-- Left Info Block (5 cols) -->
      <div class="contact-info-block">
        <span class="badge">{t('contact.hero.badge')}</span>
        <h1>{t('contact.hero.title')}<span class="text-gradient">{t('contact.hero.titleGradient')}</span>{t('contact.hero.titleEnd')}</h1>
        <p class="large">
          {t('contact.hero.desc')}
        </p>
 
        <div class="contact-details">
          <div class="detail-item">
            <div class="detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <span class="detail-lbl">{t('contact.details.phone')}</span>
              <span class="detail-val">+1 (604) 555-0192</span>
            </div>
          </div>
 
          <div class="detail-item">
            <div class="detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <span class="detail-lbl">{t('contact.details.email')}</span>
              <span class="detail-val">engineering@kasi.systems</span>
            </div>
          </div>
 
          <div class="detail-item">
            <div class="detail-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="detail-lbl">{t('contact.details.hq')}</span>
              <span class="detail-val">{t('footer.location')}</span>
            </div>
          </div>
        </div>
 
        <div class="contact-disclaimer">
          <p>
            {t('contact.details.disclaimer')}
          </p>
        </div>
      </div>
 
      <ContactForm />
    </div>
  </section>
  </main>
 
  <Footer />
</Layout>
 
<style>
  .contact-section {
    padding-top: calc(var(--space-12) + 40px);
    padding-bottom: var(--space-11);
  }

  .contact-grid {
    align-items: flex-start;
    gap: 32px;
  }

  /* Left Block */
  .contact-info-block {
    grid-column: 1 / 6;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-info-block h1 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .detail-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .detail-icon {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: rgba(0, 157, 255, 0.05);
    border: 1px solid rgba(0, 157, 255, 0.15);
    color: var(--color-electric-blue);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail-lbl {
    font-size: 0.75rem;
    font-family: var(--font-secondary);
    color: var(--color-silver-dark);
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-val {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-white);
    font-family: var(--font-primary);
  }

  .contact-disclaimer {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(230, 231, 234, 0.05);
    padding: 12px 16px;
    border-radius: 8px;
    margin-top: var(--space-3);
  }

  .lock-icon {
    font-size: 1.1rem;
  }

  .contact-disclaimer p {
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--color-silver-dark);
  }
</style>
