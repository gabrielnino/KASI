---
import Layout from '../shared/layouts/Layout.astro';
import Navbar from '../shared/components/Navbar.astro';
import Footer from '../shared/components/Footer.astro';
import PipelineDiagram from '../features/solutions/components/PipelineDiagram.astro';
---

<Layout 
  title="Artificial Intelligence Systems & Technical Pipelines" 
  description="Architecture of intelligent systems and high-resiliency data pipelines. Discover our capabilities in local models, ETL, and architectural robustness."
>
  <Navbar />

  <main>
  <!-- Hero with digital network visual -->
  <section class="solutions-hero">
    <div class="glow-blur glow-cyan" style="top: 15%; right: 10%;"></div>
    <div class="container hero-grid grid-12">
      <div class="hero-left">
        <span class="badge">Specialized AI Systems</span>
        <h1>AI Solutions & Data Architectures</h1>
        <p class="large">
          We deploy custom intelligent infrastructure. From local autonomous agents to block-tolerant massive extraction workflows.
        </p>
        <a href="#capabilities" class="btn-primary">View Capabilities</a>
      </div>
      <div class="hero-right">
        <PipelineDiagram />
      </div>
    </div>
  </section>

  <!-- Capabilities Section (2x3 Grid) -->
  <section class="capabilities-section" id="capabilities">
    <div class="container">
      <div class="section-header">
        <span class="badge">Our Capabilities</span>
        <h2>Technical Engineering Without Sales Pitch Boundaries</h2>
        <p>We design decoupled, efficient components prepared to perform under high-demand scenarios.</p>
      </div>

      <div class="capabilities-grid">
        <div class="card cap-card">
          <span class="cap-number">01</span>
          <div>
            <h3>Secure Local LLMs</h3>
            <p>Deployment of Llama, Mistral, and Phi models on on-premises hardware, ensuring absolute privacy under strict data regulations without relying on third-party APIs.</p>
          </div>
        </div>

        <div class="card cap-card">
          <span class="cap-number">02</span>
          <div>
            <h3>Structured Extraction Agents</h3>
            <p>Cognitive models specialized in processing semi-structured PDFs, invoices, and customs manifests, converting them into clean JSON records with validated schemas.</p>
          </div>
        </div>

        <div class="card cap-card">
          <span class="cap-number">03</span>
          <div>
            <h3>Captcha-Resilient Crawlers</h3>
            <p>Web scraping bots with smart residential proxy rotation, human navigation simulation, and dynamic adaptability to target source code modifications.</p>
          </div>
        </div>

        <div class="card cap-card">
          <span class="cap-number">04</span>
          <div>
            <h3>Concurrent Processing Pipelines</h3>
            <p>Distributed messaging queue systems (RabbitMQ, Apache Kafka) processing millions of daily records with guaranteed consistency and fault tolerance.</p>
          </div>
        </div>

        <div class="card cap-card">
          <span class="cap-number">05</span>
          <div>
            <h3>API Integrations & RPA Automation</h3>
            <p>Seamless connection of legacy systems using logical emulation and robust RPA bots when no APIs are available or legacy systems are closed.</p>
          </div>
        </div>

        <div class="card cap-card">
          <span class="cap-number">06</span>
          <div>
            <h3>Instrumentation & Technical Alerts</h3>
            <p>Deep health monitoring of network, RAM usage, and data throughput rates with predictive alerting mechanisms for anomalies.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Section: 5/7 Layout -->
  <section class="technical-deep-dive">
    <div class="container grid-12 tech-grid">
      <!-- Left: Technical Text (5 cols) -->
      <div class="tech-text-block">
        <span class="badge">Pipeline Architecture</span>
        <h2>How We Structure a Fault-Tolerant Pipeline</h2>
        <p>
          We do not write improvised scripts. Our systems follow rigid **Clean Architecture** principles and established design patterns:
        </p>
        <ul class="tech-feature-list">
          <li>
            <strong>Total Decoupling:</strong> Business logic is completely isolated from databases, third-party APIs, and web frameworks.
          </li>
          <li>
            <strong>Circuit Breakers:</strong> If an external service fails, the system automatically isolates itself and retries when it recovers, preventing cascading bottlenecks.
          </li>
          <li>
            <strong>Rigorous Validation Layer:</strong> Every piece of incoming data undergoes schema validation (Zod/Pydantic) before interacting with the main domain.
          </li>
          <li>
            <strong>Exponential Retries:</strong> Retry algorithms with jitter to smooth request spikes and prevent IP bans.
          </li>
        </ul>
      </div>

      <!-- Right: Technical Diagram (7 cols) -->
      <div class="tech-diagram-block">
        <div class="diagram-wrapper">
          <div class="diagram-header">
            <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
            <span class="diagram-title">KASI Resilient Pipeline Flow</span>
          </div>
          <div class="diagram-body">
            
            <div class="diagram-node source-node">
              <span class="node-tag">IN</span>
              <span>Unstructured Data Sources</span>
            </div>
            
            <div class="diagram-arrow">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            </div>
            
            <div class="diagram-node filter-node">
              <span class="node-tag">STEP 1</span>
              <span>Proxy / Decryption / Extraction</span>
            </div>
 
            <div class="diagram-arrow">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            </div>
 
            <div class="diagram-node validation-node">
              <span class="node-tag">STEP 2</span>
              <span>Schema & Validation (Fault Tolerance)</span>
            </div>
 
            <div class="diagram-arrow">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            </div>
 
            <div class="diagram-node ai-node">
              <span class="node-tag">STEP 3</span>
              <span>Local AI Agent (Llama Parse & Normalization)</span>
            </div>
 
            <div class="diagram-arrow">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            </div>
 
            <div class="diagram-node destination-node">
              <span class="node-tag">OUT</span>
              <span>Clean Destination (Data Warehouse / CRM / ERP)</span>
            </div>
 
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Big Final CTA: Build Intelligent Systems -->
  <section class="solutions-cta-section">
    <div class="container solutions-cta-box">
      <h2>Ready to build real engineering systems?</h2>
      <p class="large">
        We design custom resilient systems that minimize operational losses and optimize corporate data processing.
      </p>
      <a href="/contact?ref=solutions" class="btn-primary">Build My Intelligent Systems</a>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .solutions-hero {
    padding-top: calc(var(--space-12) + 40px);
    padding-bottom: var(--space-10);
    align-items: center;
  }

  .hero-left {
    grid-column: 1 / 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
  }

  .hero-right {
    grid-column: 7 / 13;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Capabilities Grid (2x3) */
  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .cap-card {
    min-height: 240px;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-5);
    padding: var(--space-6);
  }

  .cap-number {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-cyan-accent);
    line-height: 1;
    font-family: var(--font-primary);
  }

  .cap-card h3 {
    margin-bottom: var(--space-2);
    font-size: 1.25rem;
  }

  .cap-card p {
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Technical Deep Dive (5/7) */
  .technical-deep-dive {
    background: rgba(2, 11, 24, 0.4);
    border-block: 1px solid rgba(230, 231, 234, 0.08);
  }

  .tech-grid {
    align-items: center;
  }

  .tech-text-block {
    grid-column: 1 / 6;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .tech-feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-2);
  }

  .tech-feature-list li {
    font-family: var(--font-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    position: relative;
    padding-left: var(--space-5);
    color: var(--color-silver);
  }

  .tech-feature-list li strong {
    color: var(--color-white);
  }

  .tech-feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-cyan-accent);
  }

  .tech-diagram-block {
    grid-column: 6 / 13;
    padding-left: var(--space-5);
  }

  /* Diagram styles */
  .diagram-wrapper {
    background: rgba(6, 27, 51, 0.6);
    border: 1px solid rgba(230, 231, 234, 0.1);
    border-radius: 16px;
    overflow: hidden;
    backdrop-filter: blur(10px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .diagram-header {
    background: rgba(2, 11, 24, 0.8);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(230, 231, 234, 0.08);
  }

  .diagram-header .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .diagram-header .dot.red { background-color: var(--color-error); }
  .diagram-header .dot.yellow { background-color: var(--color-warning); }
  .diagram-header .dot.green { background-color: var(--color-success); }

  .diagram-title {
    font-size: 0.75rem;
    font-family: var(--font-secondary);
    font-weight: 600;
    color: var(--color-silver-dark);
    margin-left: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .diagram-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .diagram-node {
    width: 100%;
    max-width: 480px;
    background: rgba(2, 11, 24, 0.8);
    border: 1px solid rgba(230, 231, 234, 0.1);
    padding: 14px 20px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-family: var(--font-secondary);
    font-size: 0.9rem;
    color: var(--color-white);
    transition: all var(--transition-fast);
  }

  .diagram-node:hover {
    border-color: var(--color-electric-blue);
    transform: scale(1.01);
    box-shadow: 0 4px 15px rgba(0, 157, 255, 0.15);
  }

  .node-tag {
    font-size: 0.65rem;
    font-weight: 700;
    background: rgba(0, 200, 255, 0.1);
    border: 1px solid rgba(0, 200, 255, 0.2);
    color: var(--color-cyan-accent);
    padding: 2px 6px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .source-node { border-left: 4px solid var(--color-silver-dark); }
  .filter-node { border-left: 4px solid var(--color-electric-blue); }
  .validation-node { border-left: 4px solid var(--color-warning); }
  .ai-node { border-left: 4px solid var(--color-cyan-accent); }
  .destination-node { border-left: 4px solid var(--color-success); }

  .diagram-arrow {
    color: rgba(230, 231, 234, 0.3);
    animation: floatArrow 2s infinite ease-in-out;
  }

  @keyframes floatArrow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); color: var(--color-electric-blue); }
  }

  /* Solutions CTA Box */
  .solutions-cta-section {
    padding-block: var(--space-8);
  }

  .solutions-cta-box {
    background: radial-gradient(circle at top right, rgba(0, 200, 255, 0.1) 0%, transparent 60%), var(--grad-dark-card);
    border: 1px solid rgba(230, 231, 234, 0.08);
    border-radius: 24px;
    padding: var(--space-8);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .solutions-cta-box h2 {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    max-width: 700px;
  }

  .solutions-cta-box p {
    max-width: 600px;
    margin-bottom: var(--space-2);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .hero-left {
      grid-column: span 12;
      text-align: center;
      align-items: center;
      margin-bottom: var(--space-6);
    }

    .hero-right {
      grid-column: span 12;
    }

    .capabilities-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .tech-text-block {
      grid-column: span 12;
      margin-bottom: var(--space-6);
    }

    .tech-diagram-block {
      grid-column: span 12;
      padding-left: 0;
    }
  }

  @media (max-width: 768px) {
    .solutions-hero {
      padding-top: calc(var(--space-10) + 60px);
    }

    .cap-card {
      min-height: auto;
      flex-direction: column;
      gap: var(--space-3);
    }

    .solutions-cta-box {
      padding: var(--space-6) var(--space-5);
    }

    .solutions-cta-box .btn-primary {
      width: 100%;
    }
  }
</style>
