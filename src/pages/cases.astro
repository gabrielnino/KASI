---
import Layout from '../shared/layouts/Layout.astro';
import Navbar from '../shared/components/Navbar.astro';
import Footer from '../shared/components/Footer.astro';

// Case Studies Data
const cases = [
  {
    id: "case-1",
    category: "automation",
    categoryLabel: "Website Redesign & SEO",
    title: "Vancouver Plumbing & Drain Co.",
    metrics: "+45% service bookings",
    metricsSub: "Organic leads via Google Maps SEO",
    desc: "A complete website redesign optimized for page speed, local search keywords, and a mobile-friendly click-to-call flow. Integrated trust badges and emergency scheduling links.",
    stack: ["Astro", "Tailwind CSS", "Lighthouse SEO", "Vercel"],
  },
  {
    id: "case-2",
    category: "ai",
    categoryLabel: "AI Dispatch Assistant",
    title: "Apex Emergency Plumbing",
    metrics: "$18,000 booked in Month 1",
    metricsSub: "99.9% after-hours response rate",
    desc: "Deployed a natural-language voice and SMS virtual dispatcher that handles weekend calls, queries booking urgency, and registers technician appointments 24/7.",
    stack: ["OpenAI API", "Twilio Voice", "Node.js", "Housecall Pro API"],
  },
  {
    id: "case-3",
    category: "automation",
    categoryLabel: "Voice CRM Integration",
    title: "Fraser Valley Drain Technicians",
    metrics: "1.5 hours saved/day per tech",
    metricsSub: "-80% billing dispatch delay",
    desc: "Integrated a custom hands-free voice transcription pipeline. On-site technicians dictate summaries directly into the CRM without manual typing under constraints.",
    stack: ["Whisper Speech API", "FastAPI", "ServiceTitan API", "TypeScript"],
  },
  {
    id: "case-4",
    category: "infrastructure",
    categoryLabel: "Cloud & Resiliency",
    title: "Tri-Cities Plumbing Group",
    metrics: "99.99% website uptime",
    metricsSub: "No customer lost during peak storms",
    desc: "Migrated legacy shared hosting to a serverless Edge-based static platform with an offline fallback lead vault. Bookings are preserved even if database connections drop.",
    stack: ["Vercel Edge", "AWS DynamoDB", "Astro SSG", "Terraform"],
  },
  {
    id: "case-5",
    category: "ai",
    categoryLabel: "AI Virtual Assistant",
    title: "North Shore Plumbing & Heating",
    metrics: "-60% office booking workload",
    metricsSub: "Direct sync with technician boards",
    desc: "Created a conversational SMS booking agent that coordinates with clients to confirm time slots, send technician arrival updates, and gather initial job photos.",
    stack: ["LangChain", "Twilio SMS", "FastAPI", "Google Calendar API"],
  },
  {
    id: "case-6",
    category: "infrastructure",
    categoryLabel: "Local SEO & Visibility",
    title: "Metro Vancouver Plumbing Solutions",
    metrics: "+250% maps visibility",
    metricsSub: "Top 3 spot on high-value terms",
    desc: "Structured schema markup and local SEO optimizations across suburban service landing pages, driving organic phone call leads with zero pay-per-click ad budget.",
    stack: ["JSON-LD Schema", "Lighthouse", "Vercel Analytics", "Astro"],
  }
];
---

<Layout 
  title="Plumber AI & Web Case Studies | KASI" 
  description="Review the measurable results we have delivered to plumbing contractors. Website redesign, AI dispatch assistants, and hands-free Voice CRMs."
>
  <Navbar />

  <main>
  <!-- Compact Hero -->
  <section class="viewport-section cases-hero">
    <div class="glow-blur glow-blue" style="top: 15%; left: 5%;"></div>
    <div class="container hero-container-compact">
      <span class="badge">Our Achievements</span>
      <h1>Code that delivers <span class="text-gradient">measurable</span> results</h1>
      <p class="large">
        We do not rely on speculation. We measure our success based on the speed of your website, local SEO rankings, and dispatcher automation.
      </p>
    </div>
  </section>

  <!-- Interactive Filters & Case Studies Grid -->
  <section class="viewport-section cases-gallery-section">
    <div class="container">
      
      <!-- Filter Bar -->
      <div class="filter-bar-wrapper">
        <div class="filter-bar" id="filter-bar">
          <button class="filter-chip active" data-filter="all">All</button>
          <button class="filter-chip" data-filter="automation">Website & SEO</button>
          <button class="filter-chip" data-filter="ai">AI Dispatch Assistants</button>
          <button class="filter-chip" data-filter="infrastructure">Resiliency & CRM</button>
        </div>
      </div>

      <!-- Grid of Cases Section 1 -->
      <div class="cases-grid grid-12">
        {cases.slice(0, 3).map((c) => (
          <div class="card case-card-item" data-category={c.category} id={c.id}>
            <div class="case-card-header">
              <span class="badge case-badge">{c.categoryLabel}</span>
              <h3>{c.title}</h3>
            </div>
            
            <div class="case-metrics-box">
              <span class="case-metric-main">{c.metrics}</span>
              <span class="case-metric-sub">{c.metricsSub}</span>
            </div>

            <p class="case-desc">{c.desc}</p>

            <div class="case-footer">
              <div class="case-stack">
                {c.stack.map(tech => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
              <a href="/contact" class="case-action-link">Discuss similar solution →</a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Case Studies Grid Section 2 -->
  <section class="viewport-section cases-gallery-section">
    <div class="container">
      
      <!-- Grid of Cases Section 2 -->
      <div class="cases-grid grid-12">
        {cases.slice(3).map((c) => (
          <div class="card case-card-item" data-category={c.category} id={c.id}>
            <div class="case-card-header">
              <span class="badge case-badge">{c.categoryLabel}</span>
              <h3>{c.title}</h3>
            </div>
            
            <div class="case-metrics-box">
              <span class="case-metric-main">{c.metrics}</span>
              <span class="case-metric-sub">{c.metricsSub}</span>
            </div>

            <p class="case-desc">{c.desc}</p>

            <div class="case-footer">
              <div class="case-stack">
                {c.stack.map(tech => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
              <a href="/contact" class="case-action-link">Discuss similar solution →</a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Frictionless CTA -->
  <section class="viewport-section cases-cta-section">
    <div class="container text-center">
      <h2>Want to see similar results in your plumbing business?</h2>
      <p class="large max-width-600">
        We design a preliminary analysis of your website, local SEO, and scheduling workflow with no commitments. We identify bottlenecks immediately.
      </p>
      <a href="/contact?ref=cases" class="btn-primary">Start Free Diagnostic</a>
    </div>
  </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .cases-hero {
    text-align: center;
  }

  .hero-container-compact {
    max-width: 800px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  /* Filters */
  .filter-bar-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-7);
    overflow-x: auto;
    padding-bottom: var(--space-2);
    -webkit-overflow-scrolling: touch;
  }

  .filter-bar {
    display: flex;
    gap: var(--space-3);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(230, 231, 234, 0.08);
    padding: 6px;
    border-radius: 12px;
    min-width: max-content;
  }

  .filter-chip {
    background: transparent;
    border: none;
    color: var(--color-silver-dark);
    padding: 10px 18px;
    font-size: 0.88rem;
    font-weight: 600;
    font-family: var(--font-primary);
    cursor: pointer;
    border-radius: 8px;
    transition: all var(--transition-fast);
  }

  .filter-chip:hover {
    color: var(--color-white);
  }

  .filter-chip.active {
    background: rgba(0, 157, 255, 0.1);
    color: var(--color-cyan-accent);
    border: 1px solid rgba(0, 157, 255, 0.15);
  }

  /* Grid & Card Item */
  .cases-grid {
    gap: 24px;
  }

  .case-card-item {
    grid-column: span 4;
    min-height: 390px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-5);
    transition: all var(--transition-normal);
  }

  /* When filtered out */
  .case-card-item.hidden {
    display: none;
  }

  .case-card-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .case-badge {
    background: rgba(0, 200, 255, 0.06);
    border-color: rgba(0, 200, 255, 0.15);
    color: var(--color-cyan-accent);
  }

  .case-card-header h3 {
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .case-metrics-box {
    background: linear-gradient(90deg, rgba(0, 157, 255, 0.08), transparent);
    border-left: 3px solid var(--color-electric-blue);
    padding: 14px 18px;
    border-radius: 0 12px 12px 0;
    margin-block: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .case-metric-main {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.1;
    font-family: var(--font-primary);
  }

  .case-metric-sub {
    font-size: 0.8rem;
    color: var(--color-silver-dark);
    font-weight: 500;
  }

  .case-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .case-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    border-top: 1px solid rgba(230, 231, 234, 0.06);
    padding-top: var(--space-4);
  }

  .case-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tech-tag {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-silver-dark);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(230, 231, 234, 0.05);
    padding: 3px 6px;
    border-radius: 4px;
  }

  .case-action-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-electric-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* CTA Section */
  .cases-cta-section {
  }

  .text-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    text-align: center;
  }

  .max-width-600 {
    max-width: 600px;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .case-card-item {
      grid-column: span 6;
    }
  }

  @media (max-width: 768px) {
    .filter-bar-wrapper {
      justify-content: flex-start;
      margin-inline: -20px;
      padding-inline: 20px;
    }

    .case-card-item {
      grid-column: span 12;
      min-height: auto;
    }

    .cases-cta-section .btn-primary {
      width: 100%;
    }
  }
</style>

<script>
  function setupFilters() {
    const filterChips = document.querySelectorAll('.filter-chip');
    const cases = document.querySelectorAll('.case-card-item');

    if (!filterChips.length || !cases.length) return;

    filterChips.forEach(chip => {
      chip.addEventListener('click', () => {
        // Toggle active chip
        filterChips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');

        const filterValue = chip.getAttribute('data-filter');

        cases.forEach(item => {
          const itemCategory = item.getAttribute('data-category');

          if (filterValue === 'all' || itemCategory === filterValue) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });
  }

  // Bind immediately and on client-side route changes
  document.addEventListener('astro:page-load', setupFilters);
</script>
